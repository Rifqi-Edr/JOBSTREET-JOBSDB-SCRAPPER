{
  "title": "Jobstreet Scraper Input Config",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "keyword": {
      "title": "Search Keyword",
      "type": "string",
      "description": "Job title or keyword to search",
      "prefill": "python",
      "editor": "textfield"
    },
    "siteKey": {
      "title": "Regional Site Key",
      "type": "string",
      "description": "Site key targeting a regional job board",
      "prefill": "SG-Main",
      "editor": "select",
      "enum": [
        "MY-Main",
        "SG-Main",
        "PH-Main",
        "ID-Main",
        "TH-Main",
        "HK-Main",
        "AU-Main",
        "NZ-Main"
      ],
      "enumTitles": [
        "Malaysia (MY-Main)",
        "Singapore (SG-Main)",
        "Philippines (PH-Main)",
        "Indonesia (ID-Main)",
        "Thailand (TH-Main)",
        "Hong Kong (HK-Main)",
        "Australia (AU-Main)",
        "New Zealand (NZ-Main)"
      ]
    },
    "where": {
      "title": "Location Filter",
      "type": "string",
      "description": "Specific location or region (optional)",
      "prefill": "",
      "editor": "textfield"
    },
    "maxItems": {
      "title": "Max Items",
      "type": "integer",
      "description": "Max job postings to scrape",
      "prefill": 50,
      "minimum": 1,
      "editor": "number"
    }
  },
  "required": [
    "keyword",
    "siteKey"
  ]
}
